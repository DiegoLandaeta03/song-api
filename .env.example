# Example: http://127.0.0.1:6493/api/spotify/callback
SPOTIFY_REDIRECT_URI=
SPOTIFY_TOKEN_FILE=./spotify_token.json
HOST=0.0.0.0
PORT=8000
RATE_LIMIT=60/minute
SEARCH_CACHE_MAX_SIZE=500
SONG_CACHE_MAX_MB=2048
