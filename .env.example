MASTER_API_KEY=mxd_master_CHANGEME
AUTH_REQUIRED=false
SONGS_DIR=./songs
SONG_LIBRARY_DIR=./songs/library
# Docker only: host path mounted to /songs in container
# HOST_SONGS_DIR=/Volumes/Deegs Drive/Vanessa's Quince
API_KEYS_FILE=./api_keys.json
SONG_CACHE_DIR=./songs/cache
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
